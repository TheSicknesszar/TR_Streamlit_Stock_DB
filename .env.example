# RefurbAdmin AI - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=RefurbAdmin AI
APP_ENV=development  # development, staging, production
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Timezone (South African Standard Time)
TIMEZONE=Africa/Johannesburg

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/refurbadmin_dev.db

# For Production (PostgreSQL) - Uncomment and configure for production
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/refurbadmin_ai

# Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_V1_PREFIX=/api/v1
API_KEY_HEADER=X-API-Key
API_KEY_EXPIRY_DAYS=90

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Encryption key for POPIA-compliant PII storage (32-byte Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Password hashing
BCRYPT_ROUNDS=12

# =============================================================================
# PRICING ENGINE SETTINGS
# =============================================================================
# Default warranty period (months)
DEFAULT_WARRANTY_MONTHS=3

# Minimum margin percentage
MIN_MARGIN_PERCENT=25

# Maximum discount percentage (requires manager override)
MAX_DISCOUNT_PERCENT=15

# Velocity thresholds
SLOW_MOVING_DAYS=30
SLOW_MOVING_STOCK_THRESHOLD=5
HIGH_DEMAND_STOCK_THRESHOLD=3

# Velocity adjustment percentages
SLOW_MOVING_DISCOUNT=0.10
HIGH_DEMAND_PREMIUM=0.05

# Market data cache expiry (hours)
MARKET_DATA_CACHE_HOURS=24

# =============================================================================
# WEB SCRAPING SETTINGS
# =============================================================================
# Rate limiting (requests per second)
SCRAPER_RATE_LIMIT=1.0

# Maximum concurrent scrapers
SCRAPER_MAX_CONCURRENT=5

# Request timeout (seconds)
SCRAPER_TIMEOUT=30

# User agent for scrapers
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# =============================================================================
# LOGGING SETTINGS
# =============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text
LOG_FILE=data/logs/refurbadmin.log

# =============================================================================
# NOTIFICATION SETTINGS (Optional)
# =============================================================================
# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@refurbadmin.co.za
SMTP_FROM_NAME=RefurbAdmin AI

# WhatsApp Configuration (Optional)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_PHONE=+27123456789

# =============================================================================
# BUSINESS SETTINGS (South African Context)
# =============================================================================
CURRENCY_CODE=ZAR
CURRENCY_SYMBOL=R
COUNTRY_CODE=ZA

# Business Hours (SAST)
BUSINESS_HOUR_START=08:00
BUSINESS_HOUR_END=17:00

# Quote validity period (hours)
QUOTE_VALIDITY_HOURS=48
