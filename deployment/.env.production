# =============================================================================
# RefurbAdmin AI - Production Environment Configuration
# =============================================================================
# South African Context: POPIA Compliant Configuration
# IMPORTANT: Generate new secrets for production! Never use defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=RefurbAdmin AI
APP_ENV=production
APP_DEBUG=false
APP_URL=https://refurbadmin.co.za
APP_TIMEZONE=Africa/Johannesburg
APP_LOCALE=en_ZA

# Secret key - GENERATE NEW KEY FOR PRODUCTION!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# API Settings
API_V1_PREFIX=/api/v1
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_RPM=60
API_RATE_LIMIT_RPH=1000
API_RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Docker internal connection (for containers)
DATABASE_URL=postgresql://refurbadmin:CHANGE_ME_PASSWORD@db:5432/refurbadmin

# Individual connection parameters
POSTGRES_USER=refurbadmin
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=refurbadmin
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# Cache settings
CACHE_DEFAULT_TIMEOUT=300
CACHE_PREFIX=refurbadmin:

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# CORS Settings
CORS_ORIGINS=https://refurbadmin.co.za,https://www.refurbadmin.co.za
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,X-Request-ID

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Settings
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_UPPERCASE=true

# Session Settings
SESSION_COOKIE_NAME=refurbadmin_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Audit Logging (POPIA Compliance)
# -----------------------------------------------------------------------------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=true
AUDIT_LOG_DB=true
AUDIT_LOG_CONSOLE=false
AUDIT_LOG_DIR=/app/logs/audit
AUDIT_RETENTION_DAYS=90
AUDIT_ANONYMIZE_DAYS=365

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=noreply@refurbadmin.co.za
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_EMAIL=noreply@refurbadmin.co.za
SMTP_FROM_NAME=RefurbAdmin AI

# South African Email Providers (alternative configurations)
# For Hetzner: smtp.hetzner.co.za:587
# For Afrihost: smtp.afrihost.co.za:587
# For Office365: smtp.office365.com:587

# -----------------------------------------------------------------------------
# WhatsApp Configuration (South African Integration)
# -----------------------------------------------------------------------------
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_API_KEY=CHANGE_ME_WHATSAPP_KEY
WHATSAPP_PHONE_NUMBER=+27123456789

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,csv,xlsx,xls

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_DIR=/app/data/backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM SAST

# Cloud Storage (optional - for offsite backups)
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=af-south-1  # Cape Town region

# Azure Blob Storage (alternative)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER_NAME=

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_DIR=/app/logs/app

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PREFIX=refurbadmin

# Health Check Settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# -----------------------------------------------------------------------------
# Performance Settings
# -----------------------------------------------------------------------------
WORKERS=4
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65
CLIENT_MAX_BODY_SIZE=10M

# -----------------------------------------------------------------------------
# pgAdmin Configuration
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@refurbadmin.co.za
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Grafana Configuration (Monitoring)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_WHATSAPP_NOTIFICATIONS=false
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_AUTO_BACKUP=true
FEATURE_RATE_LIMITING=true
FEATURE_AUDIT_LOGGING=true

# -----------------------------------------------------------------------------
# POPIA Compliance Settings
# -----------------------------------------------------------------------------
# Data retention periods (in days)
POPPIA_USER_DATA_RETENTION_DAYS=730  # 2 years
POPPIA_LOG_RETENTION_DAYS=365  # 1 year
POPPIA_BACKUP_RETENTION_DAYS=90  # 3 months

# Consent management
POPPIA_CONSENT_REQUIRED=true
POPPIA_CONSENT_TEXT=By using this system, you consent to the processing of your personal information in accordance with our Privacy Policy and POPIA.

# Data subject rights
POPPIA_DATA_ACCESS_ENABLED=true
POPPIA_DATA_CORRECTION_ENABLED=true
POPPIA_DATA_DELETION_ENABLED=true

# -----------------------------------------------------------------------------
# South African Specific Settings
# -----------------------------------------------------------------------------
# Currency
DEFAULT_CURRENCY=ZAR
CURRENCY_SYMBOL=R

# Phone Number Format
DEFAULT_COUNTRY_CODE=ZA
PHONE_NUMBER_PREFIX=+27

# Business Hours (SAST)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=17:00
BUSINESS_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday

# Public Holidays (South Africa)
# Handled by application logic

# -----------------------------------------------------------------------------
# Third-Party API Keys (Optional)
# -----------------------------------------------------------------------------
# Pricing data sources
SCRAPER_API_KEY=
OPENEXCHANGERATES_API_KEY=

# SMS Gateway (South African providers)
# BulkSMS: www.bulksms.com
# ClickSend: www.clicksend.com
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=

# =============================================================================
# END OF PRODUCTION CONFIGURATION
# =============================================================================
# REMINDER:
# 1. Change all CHANGE_ME_* values
# 2. Generate new SECRET_KEY and JWT_SECRET_KEY
# 3. Review POPIA compliance settings
# 4. Configure backup retention according to your policy
# 5. Set up SSL certificates for nginx
# =============================================================================
